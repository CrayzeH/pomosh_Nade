<script>
    let activeSquadName = 'РљР»РµРІРµСЂ';
    let activeSquadId = null;
    let teamMembers = [];
    let teamStartIndex = 0;

    function escapeHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function getSquadShortName() {
        const pathMatch = window.location.pathname.match(/^\/squad\/([^/]+)\/?$/);
        if (pathMatch) return decodeURIComponent(pathMatch[1]);
        return new URLSearchParams(window.location.search).get('squad') || 'klever';
    }

    function setTheme(colors) {
        const root = document.documentElement;
        root.style.setProperty('--green', colors.primary);
        root.style.setProperty('--green-dark', colors.dark);
        root.style.setProperty('--green-soft', colors.soft);
        root.style.setProperty('--lavender', colors.light);
    }

    function setSquadPanelTextMode(shortName) {
        const whitePanelSquads = new Set([
            'vokrug-sveta',
            'prospekt',
            'zhar-ptitsa',
            'everest',
            'krylya',
            'femida',
            'shum'
        ]);

        document.body.classList.toggle('squad-white-panels', whitePanelSquads.has(shortName));
    }

    function renderHero(page) {
        document.querySelector('.hero-kicker').textContent = page.heroKicker || '';
        document.querySelector('.hero h1').innerHTML = String(page.heroTitle || '')
            .split('\n')
            .map((line, index) => index === 0
                ? `<span class="hero-title-line">${escapeHtml(line)}</span>`
                : escapeHtml(line))
            .join('<br>');

        document.querySelector('.hero-list').innerHTML = page.heroBullets
            .map((item) => `<li>${escapeHtml(item)}</li>`)
            .join('');

        const heroImage = document.querySelector('.hero-photo img');
        heroImage.src = page.heroImage;
        heroImage.alt = page.heroImageAlt || '';

        document.querySelector('.primary-btn').addEventListener('click', () => {
            document.getElementById('path')?.scrollIntoView({ behavior: 'smooth' });
        });
        document.querySelector('.outline-btn').addEventListener('click', () => {
            document.getElementById('trust')?.scrollIntoView({ behavior: 'smooth' });
        });
    }

    function renderAchievements(page) {
        document.querySelector('.achievement-grid').innerHTML = `
            <div class="achievement green">
                <img class="achievement-icon" src="/images/hero-hands.png" alt="">
                ${escapeHtml(page.achievementPrimaryText)}
            </div>
            <div class="achievement">
                <img class="achievement-icon" src="/images/hero-fire.png" alt="">
                ${escapeHtml(page.achievementSecondaryText)}
            </div>
        `;
    }

    function trustClass(colorRole) {
        const map = {
            main: 'trust-main',
            wide: 'trust-wide',
            blue: 'trust-small trust-blue',
            yellow: 'trust-small trust-yellow',
            orange: 'trust-small trust-orange'
        };
        return map[colorRole] || 'trust-small trust-blue';
    }

    function renderTrust(page) {
        const trust = document.getElementById('trust');
        trust.querySelector('.section-title').textContent = page.trustTitle;
        trust.querySelector('.trust-grid').innerHTML = page.trustCards.map((card, index) => {
            const hasBg = index === 0 && page.trustPrimaryBgImage;
            const style = hasBg ? ` style="background-image: url('${escapeHtml(page.trustPrimaryBgImage)}')"` : '';
            return `
                <article class="trust-card ${trustClass(card.color_role)}${hasBg ? ' has-bg' : ''}"${style}>
                    <h3>${escapeHtml(card.title)}</h3>
                    <p>${escapeHtml(card.body)}</p>
                </article>
            `;
        }).join('');
    }

    function renderCta(page) {
        document.querySelector('.cta-copy h2').textContent = page.ctaTitle;
        document.querySelector('.cta-copy p').textContent = page.ctaSubtitle;
        document.querySelector('.cta-btn').addEventListener('click', () => {
            document.getElementById('path')?.scrollIntoView({ behavior: 'smooth' });
        });
    }

    function renderStructure(page) {
        document.querySelector('.path-title').textContent = page.pathTitle;
        document.querySelector('.guide h3').textContent = page.guideTitle;
        document.querySelector('#structure .section-title').textContent = page.structureTitle;
        document.querySelector('.structure-list').innerHTML = page.structureSteps.map((step, index) => `
            <article class="structure-card">
                <h3>${escapeHtml(step.title)}</h3>
                <p>${escapeHtml(step.body)}</p>
                ${step.image || index === 1 || index === 2 ? `<div class="structure-art"><img src="${escapeHtml(step.image || (index === 1 ? '/images/squad-structure-step-2.png' : '/images/squad-structure-step-3.png'))}" alt=""></div>` : ''}
            </article>
        `).join('');
    }

    let structureScrollFrame = null;

    function clamp01(value) {
        return Math.max(0, Math.min(1, value));
    }

    function easeStructure(value) {
        return 1 - Math.pow(1 - value, 3);
    }

    function updateStructureScroll() {
        structureScrollFrame = null;

        const section = document.getElementById('structure');
        const pin = section?.querySelector('.structure-pin');
        const cards = Array.from(section?.querySelectorAll('.structure-card') || []);
        const canAnimate = window.matchMedia('(min-width: 901px)').matches && section && pin && cards.length >= 3;

        if (!canAnimate) {
            cards.forEach((card, index) => {
                card.style.transform = '';
                card.style.zIndex = index + 1;
            });
            return;
        }

        const rect = section.getBoundingClientRect();
        const stickyTop = Math.max(84, Math.min(window.innerWidth * 0.06, 118));
        const scrollRange = Math.max(1, section.offsetHeight - pin.offsetHeight);
        const progress = clamp01((stickyTop - rect.top) / scrollRange);
        const secondProgress = easeStructure(clamp01(progress * 2));
        const thirdProgress = easeStructure(clamp01((progress - 0.5) * 2));
        const baseGap = cards[0].offsetHeight + Math.max(42, Math.min(window.innerWidth * 0.038, 72));
        const targetGap = Math.max(22, Math.min(window.innerWidth * 0.026, 42));
        const rotations = [-3, 0, 3];

        cards[0].style.transform = `rotate(${rotations[0]}deg)`;
        cards[0].style.zIndex = 1;
        cards[1].style.transform = `translateY(${baseGap - ((baseGap - targetGap) * secondProgress)}px) rotate(${rotations[1]}deg)`;
        cards[1].style.zIndex = 2;
        cards[2].style.transform = `translateY(${(baseGap * 2) - (((baseGap * 2) - (targetGap * 2)) * thirdProgress)}px) rotate(${rotations[2]}deg)`;
        cards[2].style.zIndex = 3;
    }

    function requestStructureScrollUpdate() {
        if (structureScrollFrame !== null) return;
        structureScrollFrame = window.requestAnimationFrame(updateStructureScroll);
    }

    function initStructureScroll() {
        updateStructureScroll();
        window.addEventListener('scroll', requestStructureScrollUpdate, { passive: true });
        window.addEventListener('resize', requestStructureScrollUpdate);
    }

    function renderTeam() {
        const grid = document.querySelector('.team-grid');
        if (!teamMembers.length) {
            grid.innerHTML = '';
            return;
        }

        const visibleCount = Math.min(2, teamMembers.length);
        const visible = Array.from({ length: visibleCount }, (_, offset) => {
            return teamMembers[(teamStartIndex + offset) % teamMembers.length];
        });

        grid.innerHTML = visible.map((member) => `
            <article class="team-card">
                <div class="team-photo">
                    <img src="${escapeHtml(member.image)}" alt="${escapeHtml(member.name)}">
                    <span class="team-role">${escapeHtml(member.role)}</span>
                </div>
                <div class="team-copy">
                    <h3>${escapeHtml(member.name)}</h3>
                    <p>${escapeHtml(member.body)}</p>
                </div>
            </article>
        `).join('');
    }

    function initTeamSlider(members) {
        teamMembers = members;
        teamStartIndex = 0;
        renderTeam();

        const buttons = document.querySelectorAll('.team-controls button');
        buttons[0]?.addEventListener('click', () => {
            teamStartIndex = (teamStartIndex - 1 + teamMembers.length) % teamMembers.length;
            renderTeam();
        });
        buttons[1]?.addEventListener('click', () => {
            teamStartIndex = (teamStartIndex + 1) % teamMembers.length;
            renderTeam();
        });
    }

    async function loadSquadPage() {
        const shortName = getSquadShortName();
        const response = await fetch(`/api/squad-page/${encodeURIComponent(shortName)}`);
        const data = await response.json();

        if (!response.ok) {
            throw new Error(data.error || 'РќРµ СѓРґР°Р»РѕСЃСЊ Р·Р°РіСЂСѓР·РёС‚СЊ РѕС‚СЂСЏРґ');
        }

        activeSquadName = data.squad.name;
        activeSquadId = data.squad.id;
        document.title = data.squad.name;
        setSquadPanelTextMode(shortName);
        setTheme(data.squad.colors);
        renderHero(data.page);
        renderAchievements(data.page);
        renderTrust(data.page);
        renderCta(data.page);
        renderStructure(data.page);
        initStructureScroll();
        initTeamSlider(data.page.teamMembers);
    }

    loadSquadPage().catch((error) => {
        console.error(error);
        document.querySelector('main').innerHTML = `<section class="section page-shell"><h1>${escapeHtml(error.message)}</h1></section>`;
    });

    document.querySelectorAll('[data-page="squads"]').forEach((item) => {
        item.addEventListener('click', () => {
            document.querySelector('footer')?.scrollIntoView({ behavior: 'smooth' });
        });
    });

    const guideForm = document.getElementById('guideForm');

    function setGuideError(field, message) {
        const error = guideForm?.querySelector(`[data-error-for="${field}"]`);
        const input = guideForm?.elements[field];
        if (error) error.textContent = message;
        if (input && input.type !== 'checkbox') {
            input.classList.toggle('is-invalid', Boolean(message));
        }
    }

    function validateGuideForm() {
        const formData = new FormData(guideForm);
        const name = String(formData.get('name') || '').trim();
        const vk = String(formData.get('vk') || '').trim();
        const ageRaw = String(formData.get('age') || '').trim();
        const age = Number(ageRaw);
        const consent = guideForm.elements.consent.checked;
        const vkPattern = /^(https?:\/\/)?(www\.)?(vk\.com|vkontakte\.ru)\/[A-Za-z0-9_.-]+\/?$/i;
        let isValid = true;

        setGuideError('name', '');
        setGuideError('vk', '');
        setGuideError('age', '');
        setGuideError('consent', '');

        if (name.length < 2) {
            setGuideError('name', 'РЈРєР°Р¶Рё РёРјСЏ РјРёРЅРёРјСѓРј РёР· 2 СЃРёРјРІРѕР»РѕРІ');
            isValid = false;
        }

        if (!vkPattern.test(vk)) {
            setGuideError('vk', 'РЈРєР°Р¶Рё СЃСЃС‹Р»РєСѓ РІРёРґР° vk.com/name');
            isValid = false;
        }

        if (!Number.isInteger(age) || age < 14 || age > 25) {
            setGuideError('age', 'РЈРєР°Р¶Рё РІРѕР·СЂР°СЃС‚ РѕС‚ 14 РґРѕ 25 Р»РµС‚');
            isValid = false;
        }

        if (!consent) {
            setGuideError('consent', 'РќСѓР¶РЅРѕ СЃРѕРіР»Р°СЃРёРµ РЅР° РѕР±СЂР°Р±РѕС‚РєСѓ РґР°РЅРЅС‹С…');
            isValid = false;
        }

        return { isValid, name, vk, age };
    }

    guideForm?.addEventListener('input', (event) => {
        const field = event.target.name;
        if (field) setGuideError(field, '');
        guideForm.querySelector('.form-status').textContent = '';
        guideForm.querySelector('.form-status').className = 'form-status';
    });

    guideForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const status = guideForm.querySelector('.form-status');
        const button = guideForm.querySelector('button[type="submit"]');
        const result = validateGuideForm();

        status.textContent = '';
        status.className = 'form-status';

        if (!result.isValid) return;

        button.disabled = true;
        button.textContent = 'РћС‚РїСЂР°РІР»СЏРµРј...';

        try {
            const response = await fetch('/api/apply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    squadId: activeSquadId,
                    fullName: result.name,
                    phone: result.vk,
                    class: String(result.age)
                })
            });
            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.error || 'РќРµ СѓРґР°Р»РѕСЃСЊ РѕС‚РїСЂР°РІРёС‚СЊ С„РѕСЂРјСѓ');
            }

            guideForm.reset();
            status.textContent = `Р“РѕС‚РѕРІРѕ! Р—Р°СЏРІРєР° РІ ${activeSquadName} РѕС‚РїСЂР°РІР»РµРЅР° Рё РЅР°С…РѕРґРёС‚СЃСЏ РЅР° СЂР°СЃСЃРјРѕС‚СЂРµРЅРёРё.`;
            status.classList.add('success');
        } catch (error) {
            status.textContent = error.message || 'РћС€РёР±РєР° РѕС‚РїСЂР°РІРєРё. РџРѕРїСЂРѕР±СѓР№ РµС‰Рµ СЂР°Р·.';
            status.classList.add('error');
        } finally {
            button.disabled = false;
            button.textContent = 'РџРѕР»СѓС‡РёС‚СЊ Р±РµСЃРїР»Р°С‚РЅРѕ';
        }
    });
</script>
