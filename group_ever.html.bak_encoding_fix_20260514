        .slider-section {
            background: #F5F2FC;
            padding: 80px 0;
            position: relative;
        }

        .slider-section .container {
            position: relative;
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 5%;
        }

        .swiper-members {
            padding: 20px 0 60px;
            overflow: hidden;
            position: relative;
        }

        .swiper {
            width: 100%;
            height: auto;
            overflow: hidden;
        }

        .swiper-wrapper {
            display: flex;
            align-items: center;
        }

        .swiper-slide {
            flex-shrink: 0;
            width: 100%;
            height: auto;
            transition: transform 0.3s ease;
        }

        .swiper-slide img {
            width: 100%;
            height: 320px;
            object-fit: cover;
            border-radius: 28px;
            transition: transform 0.3s ease;
        }

        .swiper-slide:hover img {
            transform: scale(1.02);
        }

        /* РљРЅРѕРїРєРё РЅР°РІРёРіР°С†РёРё - РїРѕ Р±РѕРєР°Рј РѕС‚ РєР°СЂС‚РёРЅРѕРє */
        .swiper-button-next,
        .swiper-button-prev {
            width: 48px;
            height: 48px;
            background: white;
            border-radius: 50%;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
            transition: all 0.3s ease;
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            z-index: 999;
            cursor: pointer;
        }

        .swiper-button-next:after,
        .swiper-button-prev:after {
            font-size: 20px;
            font-weight: bold;
            color: #1F1A2E;
        }

        .swiper-button-next:hover,
        .swiper-button-prev:hover {
            background: #844DF5;
            box-shadow: 0 6px 20px rgba(132, 77, 245, 0.3);
        }

        .swiper-button-next:hover:after,
        .swiper-button-prev:hover:after {
            color: white;
        }

        .swiper-button-next {
            right: -20px;
        }

        .swiper-button-prev {
            left: -20px;
        }

        /* РџР°РіРёРЅР°С†РёСЏ (С‚РѕС‡РєРё) */
