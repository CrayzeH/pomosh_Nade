        fetch('/api/me')
            .then(res => res.json())
            .then(data => {
                if (data.user && data.user.id) {
                    if (authButtons) authButtons.style.display = 'none';
                    if (userMenu) {
                        userMenu.style.display = 'block';
                        if (userNameDisplay) {
