                description: '4 РіРѕРґР° РІ Р РЎРћ, Р·РЅР°СЋ РІСЃРµ С‚РѕРЅРєРѕСЃС‚Рё РѕС‚СЂСЏРґРЅРѕР№ Р¶РёР·РЅРё. Р Р°Р·СЂР°Р±Р°С‚С‹РІР°СЋ РїСЂРѕРіСЂР°РјРјС‹, РєРѕС‚РѕСЂС‹Рµ РґРµР»Р°СЋС‚ РЅР°СЃ СЃРёР»СЊРЅРµРµ Рё РґСЂСѓР¶РЅРµРµ.'
            },
            {
                role: 'РџР Р•РЎРЎ-РЎР•РљР Р•РўРђР Р¬',
                name: 'РќР°СЃС‚СЏ РЈСЃС‚РёРјРµРЅРєРѕ',
                photo: '/images/com-clover4.png',
                description: '3 РіРѕРґР° РІ Р РЎРћ, РЅР°С‡Р°Р»Р° СЃ С„РѕС‚РѕРіСЂР°С„РёР№, СЃС‚Р°Р»Р° РіРѕР»РѕСЃРѕРј РѕС‚СЂСЏРґР°. Р Р°СЃСЃРєР°Р¶Сѓ Рѕ РЅР°С€РёС… РїРѕР±РµРґР°С… С‚Р°Рє, С‡С‚Рѕ РІС‹ Р·Р°С…РѕС‚РёС‚Рµ Рє РЅР°Рј РїСЂРёСЃРѕРµРґРёРЅРёС‚СЊСЃСЏ!'
            }
        ];

        const buttonsContainer = document.getElementById('commanderButtons');
        const cardContainer = document.getElementById('commanderCardContainer');

        if (!buttonsContainer || !cardContainer) return;

        // РЎРѕР·РґР°РµРј РєРЅРѕРїРєРё
        buttonsContainer.innerHTML = commandersList.map((cmd, idx) => `
        <button class="commander-btn ${idx === 0 ? 'active' : ''}" data-idx="${idx}">
            ${cmd.role}
        </button>
    `).join('');

        // РџРѕРєР°Р·С‹РІР°РµРј РїРµСЂРІСѓСЋ РєР°СЂС‚РѕС‡РєСѓ
        renderCommanderCard(0);

        // Р”РѕР±Р°РІР»СЏРµРј РѕР±СЂР°Р±РѕС‚С‡РёРєРё РЅР° РєРЅРѕРїРєРё
        document.querySelectorAll('.commander-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const idx = parseInt(btn.dataset.idx);
                // РћР±РЅРѕРІР»СЏРµРј Р°РєС‚РёРІРЅС‹Р№ РєР»Р°СЃСЃ
                document.querySelectorAll('.commander-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                // РџРѕРєР°Р·С‹РІР°РµРј РєР°СЂС‚РѕС‡РєСѓ
                renderCommanderCard(idx);
            });
        });
    }

    function renderCommanderCard(index) {
        const commander = commandersList[index];
        const cardContainer = document.getElementById('commanderCardContainer');

        if (!cardContainer || !commander) return;

        cardContainer.innerHTML = `
        <div class="commander-card">
            <img class="commander-card-photo" src="${commander.photo}" alt="${commander.name}" onerror="this.src='https://via.placeholder.com/400x400?text=Photo'">
            <div class="commander-card-info">
                <div class="commander-card-name">${commander.name}</div>
                <div class="commander-card-role">${commander.role}</div>
                <div class="commander-card-desc">${commander.description}</div>
            </div>
        </div>
    `;
    }

    async function submitApplication(name, phone, userClass) {
        try {
            const response = await fetch('/api/apply', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    squadId: squadId,
                    fullName: name,
                    phone: phone,
                    class: userClass
                })
            });
            const result = await response.json();
            if (result.success) {
                alert(`РЎРїР°СЃРёР±Рѕ, ${name}! Р’Р°С€Р° Р·Р°СЏРІРєР° РІ РѕС‚СЂСЏРґ В«РљР»РµРІРµСЂВ» РїСЂРёРЅСЏС‚Р°. РњС‹ СЃРІСЏР¶РµРјСЃСЏ СЃ РІР°РјРё РїРѕ РЅРѕРјРµСЂСѓ ${phone}`);
                return true;
            } else {
                alert(result.error || 'РћС€РёР±РєР° РїСЂРё РѕС‚РїСЂР°РІРєРµ Р·Р°СЏРІРєРё');
                return false;
            }
        } catch (error) {
            console.error('РћС€РёР±РєР°:', error);
            alert('РћС€РёР±РєР° СЃРµСЂРІРµСЂР°. РџРѕРїСЂРѕР±СѓР№С‚Рµ РїРѕР·Р¶Рµ.');
            return false;
        }
    }

    const modal = document.getElementById('applicationModal');
    const openModalBtn = document.getElementById('openModalBtn');
    const closeModalBtn = document.getElementById('closeModalBtn');

    openModalBtn?.addEventListener('click', () => {
        modal.classList.add('active');
    });

    closeModalBtn?.addEventListener('click', () => {
        modal.classList.remove('active');
    });

    modal?.addEventListener('click', (e) => {
        if (e.target === modal) modal.classList.remove('active');
    });

    document.getElementById('modalJoinForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = document.getElementById('modalJoinName').value;
        const phone = document.getElementById('modalJoinPhone').value;
        const userClass = document.getElementById('modalJoinClass').value;

        if (!name || !phone || !userClass) {
            alert('Р—Р°РїРѕР»РЅРёС‚Рµ РІСЃРµ РїРѕР»СЏ');
            return;
        }

        const success = await submitApplication(name, phone, userClass);
        if (success) {
            modal.classList.remove('active');
            document.getElementById('modalJoinForm').reset();
        }
    });


    const animatedElements = document.querySelectorAll('.animate-on-scroll');
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) entry.target.classList.add('visible');
        });
    }, {threshold: 0.2});
    animatedElements.forEach(el => observer.observe(el));

    function initNavigation() {
        const navItems = document.querySelectorAll('[data-page]');
        navItems.forEach(item => {
            item.addEventListener('click', (e) => {
                const page = item.getAttribute('data-page');
                switch (page) {
                    case 'about':
                        window.location.href = '/about.html';
                        break;
                    case 'directions':
                        alert('Р Р°Р·РґРµР» "РќР°РїСЂР°РІР»РµРЅРёСЏ" РІ СЂР°Р·СЂР°Р±РѕС‚РєРµ');
                        break;
                    case 'squads':
                        document.querySelector('footer').scrollIntoView({behavior: 'smooth'});
                        break;
                    case 'create':
                        alert('Р Р°Р·РґРµР» "РЎРѕР·РґР°РІР°Р№" РІ СЂР°Р·СЂР°Р±РѕС‚РєРµ');
                        break;
                    case 'interactive':
                        alert('Р Р°Р·РґРµР» "РРЅС‚РµСЂР°РєС‚РёРІС‹" РІ СЂР°Р·СЂР°Р±РѕС‚РєРµ');
                        break;
                    case 'contacts':
                        document.querySelector('footer').scrollIntoView({behavior: 'smooth'});
                        break;
                    default:
                        break;
                }
                closeMobileMenu();
            });
        });
    }
    document.getElementById('pickHeaderBtn')?.addEventListener('click', () => {
        window.location.href = '/test.html';
    });
    document.getElementById('heroTestBtn')?.addEventListener('click', () => {
        window.location.href = '/test.html';
    });
    document.getElementById('pickSquadBtn')?.addEventListener('click', () => {
        window.location.href = '/test.html';
    });
    document.getElementById('loginHeaderBtn')?.addEventListener('click', () => {
        window.location.href = '/register.html';
    });

    // =============================================
    // РЈРџР РђР’Р›Р•РќРР• РњРћР‘РР›Р¬РќР«Рњ РњР•РќР®
    // =============================================
    const menuBtn = document.getElementById('menuToggleBtn');
    const mobileMenu = document.getElementById('mobileMenuDrop');

    function openMobileMenu() {
        mobileMenu.classList.add('open');
        document.body.classList.add('menu-open');
    }

    function closeMobileMenu() {
        mobileMenu.classList.remove('open');
        document.body.classList.remove('menu-open');
    }

    function toggleMobileMenu() {
        if (mobileMenu.classList.contains('open')) {
            closeMobileMenu();
        } else {
            openMobileMenu();
        }
    }

    if (menuBtn && mobileMenu) {
        menuBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            toggleMobileMenu();
        });

        // Р—Р°РєСЂС‹С‚РёРµ РїСЂРё РєР»РёРєРµ РЅР° РїСѓРЅРєС‚ РјРµРЅСЋ
        const menuItems = mobileMenu.querySelectorAll('span');
        menuItems.forEach(item => {
            item.addEventListener('click', () => {
                closeMobileMenu();
            });
        });

        // Р—Р°РєСЂС‹С‚РёРµ РїСЂРё РєР»РёРєРµ РІРЅРµ РјРµРЅСЋ
        document.addEventListener('click', (e) => {
            if (mobileMenu.classList.contains('open')) {
                if (!mobileMenu.contains(e.target) && !menuBtn.contains(e.target)) {
                    closeMobileMenu();
                }
            }
        });

        // Р—Р°РєСЂС‹С‚РёРµ РїСЂРё ESC
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
                closeMobileMenu();
            }
        });
    }

    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') alert(`РџРѕРёСЃРє: ${searchInput.value}`);
        });
    }

    loadCurrentUser();
    loadCommanders();
    initNavigation();
</script>
